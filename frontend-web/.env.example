# LangGraph Configuration
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_ASSISTANT_ID=coach
NEXT_PUBLIC_ALLOW_SELF_SIGNUP=false
NEXT_PUBLIC_TRIAL_CONTACT=

# LangGraph server URL (proxied by Next.js API route, not exposed to client)
LANGGRAPH_API_URL=http://localhost:2025

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
VOLITI_ALLOW_SELF_SIGNUP=false
VOLITI_TRIAL_CONTACT=

# Optional. Required for Agent Builder deployments.
# Set to "langsmith-api-key" when using a LangSmith PAT.
NEXT_PUBLIC_AUTH_SCHEME=
# Do NOT prefix this with "NEXT_PUBLIC_" as we do not want this exposed in the client.
LANGSMITH_API_KEY=
