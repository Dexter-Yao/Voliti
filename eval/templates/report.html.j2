<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Voliti Eval Report — {{ run_id }}</title>
<style>
  :root {
    --bg: #f7f4ee;
    --panel: #fffdf8;
    --ink: #1e1c19;
    --muted: #6f665c;
    --line: #ddd4c8;
    --pass: #2b6b4a;
    --fail: #a33a2b;
    --warn: #b26a1f;
    --blue: #d9ebfb;
    --sand: #f5ead7;
    --mint: #e5f1e8;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 24px;
    background: var(--bg);
    color: var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", sans-serif;
    line-height: 1.6;
  }
  .page { max-width: 1280px; margin: 0 auto; }
  h1, h2, h3 { margin: 0 0 12px; }
  h1 { font-size: 28px; }
  h2 { font-size: 20px; margin-top: 28px; }
  h3 { font-size: 16px; margin-top: 20px; }
  p { margin: 0 0 12px; }
  .meta { color: var(--muted); font-size: 14px; margin-bottom: 20px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .card, details {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 6px 24px rgba(30, 28, 25, 0.04);
  }
  .card { padding: 16px; }
  .metric-value { font-size: 24px; font-weight: 700; }
  .metric-label { color: var(--muted); font-size: 13px; }
  .panel-title { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
  }
  .badge-pass { background: var(--mint); color: var(--pass); }
  .badge-fail { background: #f8dfdb; color: var(--fail); }
  .badge-warn { background: #f8ead6; color: var(--warn); }
  .badge-source { background: #ece7df; color: var(--muted); }
  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
  }
  th, td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
    font-size: 14px;
  }
  th { background: #f1eadf; font-size: 13px; color: var(--muted); }
  tr:last-child td { border-bottom: none; }
  details { margin-top: 16px; overflow: hidden; }
  summary {
    cursor: pointer;
    padding: 16px 18px;
    font-weight: 700;
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }
  .detail-body { padding: 0 18px 18px; }
  .seed-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
    color: var(--muted);
    font-size: 13px;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .list-item {
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fffaf2;
  }
  .score-head {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
  }
  .mono, pre {
    font-family: "SFMono-Regular", "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
  }
  pre {
    margin: 0;
    padding: 12px;
    background: #f6f1e8;
    border-radius: 12px;
    border: 1px solid var(--line);
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .chat { display: flex; flex-direction: column; gap: 10px; }
  .turn {
    padding: 12px;
    border-radius: 12px;
    border: 1px solid var(--line);
    background: #fffaf2;
  }
  .turn.user { background: var(--blue); }
  .turn.coach { background: #f3eee6; }
  .turn-meta { font-size: 12px; color: var(--muted); margin-bottom: 6px; }
  @media (max-width: 960px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .two-col { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="page">
  <h1>Voliti Eval Report</h1>
  <div class="meta">
    Run ID: {{ run_id }} | {{ started_at }} | {{ seed_count }} seeds |
    Assistant: {{ config.assistant_id }} | Auditor: {{ config.auditor_model }} | Judge: {{ config.judge_model }}
  </div>

  <section class="grid">
    <div class="card">
      <div class="metric-value">{{ (summary.overall_pass_rate * 100) | round | int }}%</div>
      <div class="metric-label">总体维度通过率</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ (summary.contract_pass_rate * 100) | round | int }}%</div>
      <div class="metric-label">硬契约通过率</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ (summary.behavior_pass_rate * 100) | round | int }}%</div>
      <div class="metric-label">行为维度通过率</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ summary.must_pass_success_count }}/{{ seed_count }}</div>
      <div class="metric-label">Must-Pass 收口</div>
    </div>
  </section>

  <h2>契约失败</h2>
  {% if contract_failure_rows %}
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>失败维度</th>
        <th>证据</th>
      </tr>
    </thead>
    <tbody>
      {% for row in contract_failure_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td>
          {% for score in row.contract_failures %}
          <div>{{ score.dimension_id }}</div>
          {% endfor %}
        </td>
        <td>
          {% for score in row.contract_failures %}
          <div><span class="badge badge-source">{{ score.score_source }}</span> {{ score.justification }}</div>
          {% endfor %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="card">本次运行未出现硬契约失败。</div>
  {% endif %}

  <h2>行为失败</h2>
  {% if behavior_failure_rows %}
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>失败维度</th>
        <th>证据</th>
      </tr>
    </thead>
    <tbody>
      {% for row in behavior_failure_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td>
          {% for score in row.behavior_failures %}
          <div>{{ score.dimension_id }}</div>
          {% endfor %}
        </td>
        <td>
          {% for score in row.behavior_failures %}
          <div><span class="badge badge-source">{{ score.score_source }}</span> {{ score.justification }}</div>
          {% endfor %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="card">本次运行未出现行为维度失败。</div>
  {% endif %}

  <h2>Seed 详情</h2>
  {% for row in seed_rows %}
  <details>
    <summary>{{ row.seed_id }} — {{ row.seed_name }}</summary>
    <div class="detail-body">
      <div class="seed-meta">
        <span>entry_mode={{ row.entry_mode }}</span>
        <span>turns={{ row.turn_count }}</span>
        <span>end={{ row.end_reason }}</span>
        <span>pass={{ row.pass_rate_pct }}%</span>
        {% if row.must_pass_met %}
        <span class="badge badge-pass">Must-Pass OK</span>
        {% else %}
        <span class="badge badge-fail">Must-Pass Fail</span>
        {% endif %}
      </div>

      {% if row.overall_assessment %}
      <div class="card">{{ row.overall_assessment }}</div>
      {% endif %}

      <div class="two-col">
        <div>
          <h3>评分明细</h3>
          <div class="list">
            {% for score in row.scores %}
            <div class="list-item">
              <div class="score-head">
                <strong>{{ score.dimension_id }}</strong>
                {% if score.passed %}
                <span class="badge badge-pass">PASS</span>
                {% elif score.failure_severity == "critical" %}
                <span class="badge badge-fail">FAIL</span>
                {% else %}
                <span class="badge badge-warn">FAIL</span>
                {% endif %}
                <span class="badge badge-source">{{ score.score_source }}</span>
              </div>
              <div>{{ score.justification }}</div>
              {% if score.evidence_turns %}
              <div class="turn-meta">evidence_turns={{ score.evidence_turns | join(", ") }}</div>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>

        <div>
          <h3>Store Diff</h3>
          {% if row.store_diff_entries %}
          <div class="list">
            {% for diff in row.store_diff_entries %}
            <div class="list-item">
              <div class="score-head">
                <strong class="mono">{{ diff.key }}</strong>
                <span class="badge badge-source">{{ diff.change_type }}</span>
              </div>
              {% if diff.before_content %}
              <div class="turn-meta">Before</div>
              <pre>{{ diff.before_content }}</pre>
              {% endif %}
              {% if diff.after_content %}
              <div class="turn-meta" style="margin-top: 8px;">After</div>
              <pre>{{ diff.after_content }}</pre>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">未捕获到 store diff。</div>
          {% endif %}
        </div>
      </div>

      <div class="two-col">
        <div>
          <h3>Tool Calls</h3>
          {% if row.tool_calls %}
          <div class="list">
            {% for call in row.tool_calls %}
            <div class="list-item">
              <div class="score-head">
                <strong>{{ call.name }}</strong>
                <span class="badge badge-source">Turn {{ call.turn_index }}</span>
              </div>
              <pre>{{ call.arguments }}</pre>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">未捕获到工具调用。</div>
          {% endif %}
        </div>

        <div>
          <h3>Relevant Final Files</h3>
          {% if row.relevant_final_files %}
          <div class="list">
            {% for file in row.relevant_final_files %}
            <div class="list-item">
              <div class="turn-meta mono">{{ file.key }}</div>
              <pre>{{ file.content }}</pre>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">未找到 relevant final files。</div>
          {% endif %}
        </div>
      </div>

      <h3>Transcript</h3>
      <div class="chat">
        {% for turn in row.seed_result.transcript.turns %}
        <div class="turn {{ turn.role }}">
          <div class="turn-meta">Turn {{ turn.index }} | {{ turn.role }}</div>
          {% if turn.text %}
          <div>{{ turn.text }}</div>
          {% endif %}
          {% if turn.a2ui_payload %}
          <div class="turn-meta" style="margin-top: 8px;">A2UI Payload</div>
          <pre>{{ turn.a2ui_payload | tojson(indent=2) }}</pre>
          {% endif %}
          {% if turn.a2ui_response %}
          <div class="turn-meta" style="margin-top: 8px;">A2UI Response</div>
          <pre>{{ turn.a2ui_response | tojson(indent=2) }}</pre>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </details>
  {% endfor %}
</div>
</body>
</html>
