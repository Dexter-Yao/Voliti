<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Voliti Eval Report — {{ run_id }}</title>
<style>
  :root {
    --bg: #f6f1e8;
    --panel: #fffdf8;
    --panel-soft: #fbf7ef;
    --ink: #1f1b16;
    --muted: #6c6359;
    --line: #ddd4c8;
    --pass: #2f6f4e;
    --fail: #9f3c2e;
    --warn: #b1702b;
    --user: #dbe8f6;
    --coach: #f2ece3;
    --code: #f3eee6;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 24px;
    background: var(--bg);
    color: var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", sans-serif;
    line-height: 1.6;
  }
  .page { max-width: 1360px; margin: 0 auto; }
  h1, h2, h3, h4 { margin: 0 0 12px; }
  h1 { font-size: 28px; }
  h2 { font-size: 20px; margin-top: 28px; }
  h3 { font-size: 16px; margin-top: 20px; }
  h4 { font-size: 14px; margin-top: 16px; color: var(--muted); }
  p { margin: 0 0 12px; }
  .meta {
    color: var(--muted);
    font-size: 14px;
    margin-bottom: 20px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 20px;
  }
  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .card, details {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    box-shadow: 0 6px 24px rgba(31, 27, 22, 0.04);
  }
  .card { padding: 16px; }
  .metric-value { font-size: 24px; font-weight: 700; }
  .metric-label { color: var(--muted); font-size: 13px; }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    gap: 4px;
  }
  .badge-pass { background: #e5f1e8; color: var(--pass); }
  .badge-fail { background: #f8dfdb; color: var(--fail); }
  .badge-warn { background: #f8ead6; color: var(--warn); }
  .badge-source { background: #ece7df; color: var(--muted); }
  .mono, pre {
    font-family: "SFMono-Regular", "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
  }
  th, td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
    font-size: 14px;
  }
  th {
    background: #f1eadf;
    font-size: 13px;
    color: var(--muted);
  }
  tr:last-child td { border-bottom: none; }
  details {
    margin-top: 16px;
    overflow: hidden;
  }
  summary {
    cursor: pointer;
    padding: 16px 18px;
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }
  .detail-body { padding: 0 18px 18px; }
  .seed-summary-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .seed-summary-title {
    font-size: 16px;
    font-weight: 700;
  }
  .seed-summary-subtitle {
    margin-top: 6px;
    color: var(--muted);
    font-size: 13px;
  }
  .seed-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 12px;
    color: var(--muted);
    font-size: 13px;
  }
  .overview-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-bottom: 16px;
  }
  .list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .list-item {
    padding: 12px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel-soft);
  }
  .score-head {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    margin-bottom: 6px;
  }
  .section-details {
    margin-top: 14px;
    border-radius: 14px;
    background: var(--panel-soft);
  }
  .section-details > summary {
    font-weight: 700;
    padding: 14px 16px;
  }
  .section-body { padding: 0 16px 16px; }
  pre {
    margin: 0;
    padding: 12px;
    background: var(--code);
    border-radius: 12px;
    border: 1px solid var(--line);
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .raw-toggle {
    margin-top: 10px;
    border-radius: 12px;
    box-shadow: none;
  }
  .raw-toggle > summary {
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 600;
    color: var(--muted);
  }
  .markdown {
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--panel-soft);
  }
  .markdown h1,
  .markdown h2,
  .markdown h3,
  .markdown h4,
  .markdown h5,
  .markdown h6 {
    margin: 0 0 10px;
    font-size: 15px;
  }
  .markdown p:last-child,
  .markdown blockquote:last-child,
  .markdown ul:last-child,
  .markdown ol:last-child { margin-bottom: 0; }
  .markdown blockquote {
    margin: 0 0 12px;
    padding: 10px 12px;
    border-left: 3px solid #c78c4d;
    background: #f7efe1;
    color: var(--muted);
  }
  .markdown ul,
  .markdown ol {
    margin: 0 0 12px 20px;
    padding: 0;
  }
  .markdown code {
    padding: 1px 5px;
    border-radius: 6px;
    background: #eee7dc;
    font-family: "SFMono-Regular", "JetBrains Mono", ui-monospace, monospace;
    font-size: 12px;
  }
  .chat {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .turn {
    padding: 12px;
    border-radius: 12px;
    border: 1px solid var(--line);
  }
  .turn.user { background: var(--user); }
  .turn.coach { background: var(--coach); }
  .turn-meta {
    font-size: 12px;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .turn-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }
  .compact-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  @media (max-width: 1080px) {
    .grid,
    .overview-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .two-col { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .grid,
    .overview-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>
<div class="page">
  <h1>Voliti Eval Report</h1>
  <div class="meta">
    Run ID: {{ run_id }} | {{ started_at }} | {{ seed_count }} seeds |
    Profile: {{ profile.name }}{% if profile.description %} ({{ profile.description }}){% endif %} |
    Assistant: {{ config.assistant_id }} | Auditor: {{ config.auditor_model }} | Judge: {{ config.judge_model }}
  </div>
  <div class="meta">
    Server: {{ runtime.server_url or "N/A" }} | Concurrency: {{ runtime.max_concurrency if runtime.max_concurrency is not none else "N/A" }}
  </div>
  <div class="meta">
    Profile Seeds: {{ profile.seed_count }}
    {% if profile.seed_ids %}
    | {{ profile.seed_ids | join(", ") }}
    {% endif %}
  </div>

  <section class="grid">
    <div class="card">
      <div class="metric-value">{{ summary.overall_pass_rate | display_percent }}</div>
      <div class="metric-label">总体维度通过率</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ summary.user_gate_pass_rate | display_percent }}</div>
      <div class="metric-label">User Gate</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ summary.runtime_gate_pass_rate | display_percent }}</div>
      <div class="metric-label">Runtime Contract Gate</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ summary.diagnostic_pass_rate | display_percent }}</div>
      <div class="metric-label">Diagnostics</div>
    </div>
  </section>

  {% if stability %}
  <section class="grid">
    <div class="card">
      <div class="metric-value">{{ stability.run_count }}</div>
      <div class="metric-label">重复运行次数</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ stability.overall_gate_pass_k | display_percent }}</div>
      <div class="metric-label">Gate pass^k</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ stability.stable_gate_pass_rate | display_percent }}</div>
      <div class="metric-label">全部运行均通过</div>
    </div>
    <div class="card">
      <div class="metric-value">{{ stability.flake_count }}</div>
      <div class="metric-label">Flaky Seeds</div>
    </div>
  </section>
  {% endif %}

  <h2>Execution Blockers</h2>
  {% if execution_blocker_rows %}
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>状态</th>
        <th>原因</th>
        <th>需要人工跟进</th>
      </tr>
    </thead>
    <tbody>
      {% for row in execution_blocker_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td><span class="badge badge-fail">BLOCKED</span></td>
        <td>{{ row.blocking_reason or row.end_reason }}</td>
        <td>
          <div>读取最新 transcript 与 score。</div>
          {% for item in row.manual_follow_up_notes %}
          <div>{{ item }}</div>
          {% endfor %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="card">本次运行未出现 execution blocker。</div>
  {% endif %}

  <h2>User Gate Summary</h2>
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>User Gate</th>
        <th>整体 Gate</th>
        <th>核心证据 Turn</th>
        <th>为什么过 / 为什么没过</th>
      </tr>
    </thead>
    <tbody>
      {% for row in seed_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td>
          {% if row.execution_status == "blocked" %}
          <span class="badge badge-fail">BLOCKED</span>
          {% elif row.user_gate_assessed_count == 0 %}
          <span class="badge badge-source">N/A</span>
          {% elif row.user_gate_met %}
          <span class="badge badge-pass">PASS</span>
          {% else %}
          <span class="badge badge-fail">FAIL</span>
          {% endif %}
        </td>
        <td>
          {% if row.execution_status == "blocked" %}
          <span class="badge badge-fail">BLOCKED</span>
          {% elif row.must_pass_met %}
          <span class="badge badge-pass">PASS</span>
          {% else %}
          <span class="badge badge-fail">FAIL</span>
          {% endif %}
          {% if row.gate_flaky %}
          <span class="badge badge-warn">Flaky</span>
          {% endif %}
          {% if row.run_history %}
          <span class="badge badge-source">pass^k {{ "YES" if row.gate_pass_k else "NO" }}</span>
          {% endif %}
        </td>
        <td>
          {% if row.core_evidence_turns %}
          {{ row.core_evidence_turns | join(", ") }}
          {% elif row.execution_status == "blocked" %}
          阻断，需读记录
          {% else %}
          无
          {% endif %}
        </td>
        <td>
          {% if row.execution_status == "blocked" %}
            {{ row.blocking_reason or "运行中断，需人工跟进。" }}
          {% elif row.user_gate_failures %}
            {% for score in row.user_gate_failures %}
            <div><strong>{{ score.dimension_id }}</strong>：{{ score.justification }}</div>
            {% endfor %}
          {% elif row.user_gate_assessed_count == 0 %}
            User Gate 本次未评估，见人工附录。
          {% elif row.overall_assessment %}
            {{ row.overall_assessment }}
          {% else %}
            通过。
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>Runtime Contract Summary</h2>
  {% if runtime_gate_failure_rows or execution_blocker_rows %}
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>状态</th>
        <th>失败维度</th>
        <th>证据</th>
      </tr>
    </thead>
    <tbody>
      {% for row in seed_rows if row.runtime_gate_failures or row.execution_status == "blocked" %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td>
          {% if row.execution_status == "blocked" %}
          <span class="badge badge-fail">BLOCKED</span>
          {% elif row.runtime_gate_assessed_count == 0 %}
          <span class="badge badge-source">N/A</span>
          {% elif row.runtime_gate_met %}
          <span class="badge badge-pass">PASS</span>
          {% else %}
          <span class="badge badge-fail">FAIL</span>
          {% endif %}
        </td>
        <td>
          {% if row.execution_status == "blocked" %}
          <div>Execution blocked</div>
          {% elif row.runtime_gate_failures %}
            {% for score in row.runtime_gate_failures %}
            <div>{{ score.dimension_id }}</div>
            {% endfor %}
          {% else %}
          <div>N/A</div>
          {% endif %}
        </td>
        <td>
          {% if row.execution_status == "blocked" %}
          {{ row.blocking_reason or row.end_reason }}
          {% else %}
            {% for score in row.runtime_gate_failures %}
            <div><span class="badge badge-source">{{ score.score_source }}</span> {{ score.justification }}</div>
            {% endfor %}
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="card">本次运行未出现 Runtime Contract Gate 失败。</div>
  {% endif %}

  <h2>Diagnostics Summary</h2>
  {% if diagnostic_failure_rows %}
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>诊断项</th>
        <th>证据</th>
      </tr>
    </thead>
    <tbody>
      {% for row in diagnostic_failure_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td>
          {% for score in row.diagnostic_failures %}
          <div>{{ score.dimension_id }}</div>
          {% endfor %}
        </td>
        <td>
          {% for score in row.diagnostic_failures %}
          <div><span class="badge badge-source">{{ score.score_source }}</span> {{ score.justification }}</div>
          {% endfor %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <div class="card">本次运行未出现 Diagnostics 失败。</div>
  {% endif %}

  <h2>Seed Detail</h2>
  {% for row in seed_rows %}
  <details>
    <summary>
      <div class="seed-summary-row">
        <div>
          <div class="seed-summary-title">{{ row.seed_id }} — {{ row.seed_name }}</div>
          <div class="seed-summary-subtitle">
            entry_mode={{ row.entry_mode }} · turns={{ row.turn_count }} · end={{ row.end_reason }}
          </div>
        </div>
        <div class="compact-list">
          {% if row.execution_status == "blocked" %}
          <span class="badge badge-fail">BLOCKED</span>
          {% else %}
          {% if row.user_gate_met %}
          <span class="badge badge-pass">PASS</span>
          {% else %}
          <span class="badge badge-fail">FAIL</span>
          {% endif %}
          <span class="badge {% if row.user_gate_met %}badge-pass{% else %}badge-fail{% endif %}">
            User Gate {{ "OK" if row.user_gate_met else "Fail" }}
          </span>
          <span class="badge {% if row.runtime_gate_met %}badge-pass{% else %}badge-fail{% endif %}">
            Runtime {{ "OK" if row.runtime_gate_met else "Fail" }}
          </span>
          <span class="badge {% if row.must_pass_met %}badge-pass{% else %}badge-fail{% endif %}">
            Gate {{ "OK" if row.must_pass_met else "Fail" }}
          </span>
          {% endif %}
          <span class="badge badge-source">pass {{ row.pass_rate | display_percent }}</span>
          {% if row.gate_flaky %}
          <span class="badge badge-warn">Flaky</span>
          {% endif %}
          {% if row.run_history %}
          <span class="badge badge-source">pass^k {{ "YES" if row.gate_pass_k else "NO" }}</span>
          {% endif %}
        </div>
      </div>
    </summary>
    <div class="detail-body">
      <div class="seed-meta">
        <span>用户结果：{{ row.user_outcome }}</span>
      </div>

      {% if row.overall_assessment %}
      <div class="markdown">{{ row.overall_assessment | markdown_html }}</div>
      {% endif %}

      <div class="overview-grid">
        <div class="card">
          <div class="metric-value">
            {% if row.execution_status == "blocked" %}BLOCKED{% else %}{{ row.pass_rate | display_percent }}{% endif %}
          </div>
          <div class="metric-label">Seed 总通过率</div>
        </div>
        <div class="card">
          <div class="metric-value">{{ row.user_gate_pass_rate | display_percent }}</div>
          <div class="metric-label">User Gate</div>
        </div>
        <div class="card">
          <div class="metric-value">{{ row.runtime_gate_pass_rate | display_percent }}</div>
          <div class="metric-label">Runtime Contract</div>
        </div>
        <div class="card">
          <div class="metric-value">{{ row.diagnostic_pass_rate | display_percent }}</div>
          <div class="metric-label">Diagnostics</div>
        </div>
      </div>

      <details class="section-details" open>
        <summary>结果摘要</summary>
        <div class="section-body">
          {% if row.execution_status == "blocked" %}
          <div class="card">
            <strong>BLOCKED</strong><br>
            {{ row.blocking_reason or "运行中断，需人工跟进。" }}
          </div>
          {% elif row.user_gate_failures or row.runtime_gate_failures %}
          <div class="list">
            {% for score in row.user_gate_failures + row.runtime_gate_failures %}
            <div class="list-item">
              <div class="score-head">
                <strong>{{ score.dimension_id }}</strong>
                <span class="badge {% if score.failure_severity == 'critical' %}badge-fail{% else %}badge-warn{% endif %}">FAIL</span>
                <span class="badge badge-source">{{ score.score_source }}</span>
              </div>
              <div class="markdown">{{ score.justification | markdown_html }}</div>
              {% if score.evidence_turns %}
              <div class="turn-meta">evidence_turns={{ score.evidence_turns | join(", ") }}</div>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">该 seed 的正式 gate 已通过。</div>
          {% endif %}
        </div>
      </details>

      <details class="section-details" open>
        <summary>Latest Run Detail</summary>
        <div class="section-body">
          {% if row.latest_run %}
          <div class="list">
            <div class="list-item">
              <div class="score-head">
                <strong>{{ row.latest_run.run_id }}</strong>
                {% if row.latest_run.execution_status == "blocked" %}
                <span class="badge badge-fail">BLOCKED</span>
                {% elif row.latest_run.must_pass_met %}
                <span class="badge badge-pass">PASS</span>
                {% else %}
                <span class="badge badge-fail">FAIL</span>
                {% endif %}
                <span class="badge badge-source">pass {{ row.latest_run.pass_rate | display_percent }}</span>
              </div>
              <div class="turn-meta">end_reason={{ row.latest_run.end_reason }}</div>
              {% if row.latest_run.blocking_reason %}
              <div>{{ row.latest_run.blocking_reason }}</div>
              {% endif %}
              <div class="turn-meta">transcript={{ row.latest_run.transcript_path }}</div>
              <div class="turn-meta">score={{ row.latest_run.score_path }}</div>
            </div>
          </div>
          {% endif %}
        </div>
      </details>

      <details class="section-details">
        <summary>Diagnostic findings</summary>
        <div class="section-body">
          {% if row.diagnostic_failures %}
          <div class="list">
            {% for score in row.diagnostic_failures %}
            <div class="list-item">
              <div class="score-head">
                <strong>{{ score.dimension_id }}</strong>
                <span class="badge badge-warn">Diagnostic</span>
                <span class="badge badge-source">{{ score.score_source }}</span>
              </div>
              <div class="markdown">{{ score.justification | markdown_html }}</div>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">该 seed 本次未出现 diagnostic failure。</div>
          {% endif %}
        </div>
      </details>

      <details class="section-details">
        <summary>What Was Intentionally Not Auto-Scored</summary>
        <div class="section-body">
          {% if row.manual_follow_up_notes %}
          <div class="list">
            {% for item in row.manual_follow_up_notes %}
            <div class="list-item">{{ item }}</div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">该 seed 本次没有刻意排除的自动评估项。</div>
          {% endif %}
        </div>
      </details>

      <details class="section-details">
        <summary>Manual Review Appendix</summary>
        <div class="section-body">
          <div class="list">
            {% for item in row.manual_review_checks %}
            <div class="list-item">{{ item }}</div>
            {% endfor %}
          </div>
        </div>
      </details>

      {% if row.run_history %}
      <details class="section-details">
        <summary>Run Stability</summary>
        <div class="section-body">
          {% if row.gate_flaky or row.execution_status == "blocked" %}
          <div class="card">该 seed 存在 flaky 或 blocked 记录，需人工阅读相关历史 transcript。</div>
          {% endif %}
          <table>
            <thead>
              <tr>
                <th>Run</th>
                <th>Status</th>
                <th>User Gate</th>
                <th>Runtime Gate</th>
                <th>Overall Gate</th>
                <th>Pass Rate</th>
                <th>End Reason</th>
                <th>Transcript</th>
                <th>Score</th>
              </tr>
            </thead>
            <tbody>
              {% for item in row.run_history %}
              <tr>
                <td>{{ item.run_id }}</td>
                <td>{% if item.execution_status == "blocked" %}BLOCKED{% else %}COMPLETED{% endif %}</td>
                <td>{% if item.execution_status == "blocked" %}BLOCKED{% elif item.user_gate_met %}PASS{% else %}FAIL{% endif %}</td>
                <td>{% if item.execution_status == "blocked" %}BLOCKED{% elif item.runtime_gate_met %}PASS{% else %}FAIL{% endif %}</td>
                <td>{% if item.execution_status == "blocked" %}BLOCKED{% elif item.must_pass_met %}PASS{% else %}FAIL{% endif %}</td>
                <td>{{ item.pass_rate | display_percent }}</td>
                <td>{{ item.end_reason }}</td>
                <td class="mono">{{ item.transcript_path }}</td>
                <td class="mono">{{ item.score_path }}</td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </details>
      {% endif %}

      <details class="section-details" open>
        <summary>评分详情</summary>
        <div class="section-body">
          <div class="list">
            {% for score in row.scores %}
            <div class="list-item">
              <div class="score-head">
                <strong>{{ score.dimension_id }}</strong>
                {% if score.passed %}
                <span class="badge badge-pass">PASS</span>
                {% elif score.failure_severity == "critical" %}
                <span class="badge badge-fail">FAIL</span>
                {% else %}
                <span class="badge badge-warn">FAIL</span>
                {% endif %}
                <span class="badge badge-source">{{ score.score_source }}</span>
                <span class="badge badge-source">{{ score.category }}</span>
              </div>
              <div class="markdown">{{ score.justification | markdown_html }}</div>
              {% if score.evidence_turns %}
              <div class="turn-meta">evidence_turns={{ score.evidence_turns | join(", ") }}</div>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
      </details>

      <details class="section-details">
        <summary>会话记录</summary>
        <div class="section-body">
          <div class="two-col">
            <div>
              <h3>Tool Calls</h3>
              {% if row.tool_calls %}
              <div class="list">
                {% for call in row.tool_calls %}
                <div class="list-item">
                  <div class="score-head">
                    <strong>{{ call.name }}</strong>
                    <span class="badge badge-source">Turn {{ call.turn_index }}</span>
                  </div>
                  <pre>{{ call.arguments }}</pre>
                </div>
                {% endfor %}
              </div>
              {% else %}
              <div class="card">未捕获到工具调用。</div>
              {% endif %}
            </div>

            <div>
              <h3>Store Diff</h3>
              {% if row.store_diff_entries %}
              <div class="list">
                {% for diff in row.store_diff_entries %}
                <div class="list-item">
                  <div class="score-head">
                    <strong class="mono">{{ diff.key }}</strong>
                    <span class="badge badge-source">{{ diff.change_type }}</span>
                  </div>
                  {% if diff.before_content %}
                  <div class="turn-meta">Before</div>
                  <pre>{{ diff.before_content }}</pre>
                  {% endif %}
                  {% if diff.after_content %}
                  <div class="turn-meta">After</div>
                  <pre>{{ diff.after_content }}</pre>
                  {% endif %}
                </div>
                {% endfor %}
              </div>
              {% else %}
              <div class="card">未捕获到 Store 变化。</div>
              {% endif %}
            </div>
          </div>

          <h3>Transcript</h3>
          <div class="chat">
            {% for turn in row.seed_result.transcript.turns %}
            <div class="turn {{ turn.role }}">
              <div class="turn-meta">Turn {{ turn.index }} · {{ turn.role }}</div>
              {% if turn.text %}
              <div class="markdown">{{ turn.text | markdown_html }}</div>
              {% endif %}
              {% if turn.a2ui_payload %}
              <details class="raw-toggle">
                <summary>A2UI Payload</summary>
                <pre>{{ turn.a2ui_payload | pretty_json }}</pre>
              </details>
              {% endif %}
              {% if turn.a2ui_response %}
              <details class="raw-toggle">
                <summary>A2UI Response</summary>
                <pre>{{ turn.a2ui_response | pretty_json }}</pre>
              </details>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
      </details>

      <details class="section-details">
        <summary>审核材料</summary>
        <div class="section-body">
          <h3>Allowed Good Variants</h3>
          <div class="list">
            {% for item in row.allowed_good_variants %}
            <div class="list-item">{{ item }}</div>
            {% endfor %}
          </div>

          <h3>Relevant Final Files</h3>
          {% if row.relevant_final_files %}
          <div class="list">
            {% for file in row.relevant_final_files %}
            <div class="list-item">
              <div class="score-head">
                <strong class="mono">{{ file.key }}</strong>
              </div>
              {% if file.is_markdown %}
              <div class="markdown">{{ file.content | markdown_html }}</div>
              {% else %}
              <pre>{{ file.content }}</pre>
              {% endif %}
              <details class="raw-toggle">
                <summary>查看原文</summary>
                <pre>{{ file.content }}</pre>
              </details>
            </div>
            {% endfor %}
          </div>
          {% else %}
          <div class="card">没有捕获到 relevant final files。</div>
          {% endif %}

          <details class="raw-toggle">
            <summary>Auditor Prompt</summary>
            <div class="markdown">{{ row.auditor_prompt_rendered | markdown_html }}</div>
          </details>

          <details class="raw-toggle">
            <summary>Judge Prompt</summary>
            <div class="markdown">{{ row.judge_prompt_rendered | markdown_html }}</div>
          </details>

          <details class="raw-toggle">
            <summary>Seed Policy</summary>
            <h4>Expected Behaviors</h4>
            <pre>{{ row.expected_behaviors | pretty_json }}</pre>
            <h4>Expected Artifacts</h4>
            <pre>{{ row.expected_artifacts | pretty_json }}</pre>
            <h4>Scoring Focus</h4>
            <pre>{{ row.scoring_focus | pretty_json }}</pre>
            <h4>Auditor Policy</h4>
            <pre>{{ row.auditor_policy | pretty_json }}</pre>
          </details>

          <details class="raw-toggle">
            <summary>Judge Requested Dimensions</summary>
            <pre>{{ row.judge_requested_dimensions | pretty_json }}</pre>
          </details>

          <details class="raw-toggle">
            <summary>Judge Dimension Definitions</summary>
            <pre>{{ row.judge_dimension_definitions | pretty_json }}</pre>
          </details>
        </div>
      </details>
    </div>
  </details>
  {% endfor %}

  <h2>Manual Review Appendix</h2>
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        <th>刻意未自动评估</th>
        <th>人工复核项</th>
        <th>Gate 结果</th>
      </tr>
    </thead>
    <tbody>
      {% for row in seed_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        <td>
          {% if row.manual_follow_up_notes %}
            {% for item in row.manual_follow_up_notes %}
            <div>{{ item }}</div>
            {% endfor %}
          {% else %}
          <div>无</div>
          {% endif %}
        </td>
        <td>
          {% for item in row.manual_review_checks %}
          <div>{{ item }}</div>
          {% endfor %}
        </td>
        <td>
          {% if row.execution_status == "blocked" %}
          <span class="badge badge-fail">Blocked</span>
          {% elif row.must_pass_met %}
          <span class="badge badge-pass">Gate Passed</span>
          {% else %}
          <span class="badge badge-fail">Gate Failed</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
</body>
</html>
