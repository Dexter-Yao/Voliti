<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Voliti 评估报告 — {{ run_id }}</title>
<style>
  :root {
    --bg: #fafafa; --fg: #1a1a1a; --muted: #666; --border: #e0e0e0;
    --user-bg: #e8f4fd; --coach-bg: #f0f0f0; --a2ui-bg: #fff8e1;
    --pass: #2e7d32; --fail: #d32f2f; --fail-notable: #f57c00; --na: #999;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, "Helvetica Neue", sans-serif; background: var(--bg); color: var(--fg); line-height: 1.6; max-width: 100%; margin: 0 auto; padding: 2rem 2rem; }
  h1 { font-size: 1.5rem; margin-bottom: 0.25rem; }
  h2 { font-size: 1.2rem; margin: 1.5rem 0 0.75rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; }
  h3 { font-size: 1rem; margin: 1rem 0 0.5rem; }
  .meta { color: var(--muted); font-size: 0.85rem; margin-bottom: 1.5rem; }

  .summary-table { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.9rem; }
  .summary-table th, .summary-table td { padding: 0.5rem 0.75rem; border: 1px solid var(--border); text-align: left; }
  .summary-table th { background: #f5f5f5; font-weight: 600; }

  .badge { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 0.75rem; font-weight: 700; }
  .badge-pass { background: #e8f5e9; color: var(--pass); }
  .badge-fail { background: #ffebee; color: var(--fail); }
  .badge-fail-notable { background: #fff3e0; color: var(--fail-notable); }
  .badge-na { background: #f5f5f5; color: var(--na); }

  .heatmap { display: grid; gap: 2px; margin: 1rem 0; font-size: 0.7rem; overflow-x: auto; }
  .heatmap-cell { padding: 4px 6px; text-align: center; border-radius: 2px; font-weight: 600; min-width: 36px; }
  .heatmap-pass { background: #c8e6c9; color: #1b5e20; }
  .heatmap-fail { background: #ffcdd2; color: #b71c1c; }
  .heatmap-fail-notable { background: #ffe0b2; color: #e65100; }
  .heatmap-na { background: #f5f5f5; color: #999; }
  .heatmap-header { background: #f5f5f5; color: var(--fg); font-weight: 600; padding: 4px 6px; word-break: break-word; line-height: 1.3; }

  details { margin: 0.75rem 0; border: 1px solid var(--border); border-radius: 4px; }
  summary { padding: 0.75rem 1rem; cursor: pointer; font-weight: 600; background: #f9f9f9; }
  summary:hover { background: #f0f0f0; }
  .detail-content { padding: 1rem; }

  .chat { display: flex; flex-direction: column; gap: 0.5rem; margin: 0.75rem 0; }
  .bubble { max-width: 80%; padding: 0.6rem 0.9rem; border-radius: 12px; font-size: 0.9rem; white-space: pre-wrap; word-break: break-word; }
  .bubble-user { align-self: flex-start; background: var(--user-bg); border-bottom-left-radius: 2px; }
  .bubble-coach { align-self: flex-end; background: var(--coach-bg); border-bottom-right-radius: 2px; }
  .bubble-a2ui { align-self: flex-end; background: var(--a2ui-bg); border: 1px solid #ffe082; border-bottom-right-radius: 2px; font-size: 0.85rem; }
  .bubble-label { font-size: 0.7rem; color: var(--muted); margin-bottom: 2px; }

  .eval-image { max-width: 300px; border-radius: 8px; margin: 0.5rem 0; }

  .scorecard { margin: 0.75rem 0; }
  .scorecard-row { display: flex; align-items: center; gap: 0.5rem; margin: 0.25rem 0; font-size: 0.85rem; }
  .scorecard-dim { width: 220px; font-weight: 500; }
  .scorecard-verdict { width: 60px; text-align: center; }
  .scorecard-just { color: var(--muted); flex: 1; }

  .footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid var(--border); font-size: 0.8rem; color: var(--muted); }
</style>
</head>
<body>

<h1>Voliti Coach 评估报告</h1>
<div class="meta">
  Run ID: {{ run_id }} | {{ started_at }} | {{ seed_count }} seeds |
  Auditor: {{ config.auditor_model }} | Judge: {{ config.judge_model }}
</div>

{# ---- 总览仪表盘 ---- #}
<h2>总览</h2>
<table class="summary-table">
  <thead>
    <tr>
      <th>Seed</th>
      <th>Turns</th>
      <th>End</th>
      <th>Pass Rate</th>
      <th>Must-Pass</th>
      <th>Critical</th>
    </tr>
  </thead>
  <tbody>
    {% for sr in seed_results %}
    <tr>
      <td>{{ sr.seed.id }} {{ sr.seed.name }}</td>
      <td>{{ sr.transcript.turn_count }}</td>
      <td>{{ sr.transcript.end_reason }}</td>
      <td>
        {% set pct = (sr.score_card.pass_rate * 100) | round | int %}
        <span class="badge {% if pct >= 80 %}badge-pass{% elif pct >= 60 %}badge-fail-notable{% else %}badge-fail{% endif %}">
          {{ pct }}%
        </span>
        ({{ sr.score_card.scores.values() | selectattr('passed') | list | length }}/{{ sr.score_card.scores | length }})
      </td>
      <td>
        {% if sr.score_card.must_pass_met %}
        <span class="badge badge-pass">✓</span>
        {% else %}
        <span class="badge badge-fail">✗</span>
        {% endif %}
      </td>
      <td>{{ sr.score_card.critical_failures | length }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{# ---- 热力图 ---- #}
{% if all_dimensions %}
<h2>维度通过矩阵</h2>
<div class="heatmap" style="grid-template-columns: 160px repeat({{ all_dimensions | length }}, minmax(100px, 1fr));">
  <div class="heatmap-header"></div>
  {% for dim in all_dimensions %}
  <div class="heatmap-header" title="{{ dim }}">{{ dim | replace('_', ' ') }}</div>
  {% endfor %}
  {% for sr in seed_results %}
  <div class="heatmap-header">{{ sr.seed.id }}</div>
  {% for dim in all_dimensions %}
  {% set s = sr.score_card.scores.get(dim) %}
  {% if s %}
  {% if s.passed %}
  <div class="heatmap-cell heatmap-pass" title="{{ dim }}: PASS">✓</div>
  {% elif s.failure_severity == 'critical' %}
  <div class="heatmap-cell heatmap-fail" title="{{ dim }}: FAIL (critical)">✗</div>
  {% else %}
  <div class="heatmap-cell heatmap-fail-notable" title="{{ dim }}: FAIL (notable)">✗</div>
  {% endif %}
  {% else %}
  <div class="heatmap-cell heatmap-na" title="{{ dim }}: N/A">—</div>
  {% endif %}
  {% endfor %}
  {% endfor %}
</div>
{% endif %}

{# ---- 每 Seed 详情 ---- #}
<h2>详细结果</h2>
{% for sr in seed_results %}
<details>
  <summary>{{ sr.seed.id }} — {{ sr.seed.name }}（pass {{ (sr.score_card.pass_rate * 100) | round | int }}% | must {% if sr.score_card.must_pass_met %}✓{% else %}✗{% endif %}）</summary>
  <div class="detail-content">

    <h3>评分</h3>
    <div class="scorecard">
      {% for dim_id, dim in sr.score_card.scores.items() %}
      <div class="scorecard-row">
        <span class="scorecard-dim">{{ dim_id | replace('_', ' ') }}</span>
        <span class="scorecard-verdict">
          {% if dim.passed %}
          <span class="badge badge-pass">PASS</span>
          {% elif dim.failure_severity == 'critical' %}
          <span class="badge badge-fail">FAIL</span>
          {% else %}
          <span class="badge badge-fail-notable">FAIL</span>
          {% endif %}
        </span>
        <span class="scorecard-just">{{ dim.justification }}</span>
      </div>
      {% endfor %}
    </div>

    {% if sr.score_card.overall_assessment %}
    <h3>总体评估</h3>
    <p>{{ sr.score_card.overall_assessment }}</p>
    {% endif %}

    {% if sr.score_card.critical_failures %}
    <h3>关键失败</h3>
    <ul>
      {% for f in sr.score_card.critical_failures %}
      <li>{{ f }}</li>
      {% endfor %}
    </ul>
    {% endif %}

    <h3>对话记录</h3>
    <div class="chat">
      {% for turn in sr.transcript.turns %}
        {% if turn.role == "user" and turn.text %}
        <div>
          <div class="bubble-label">User (Turn {{ turn.index }})</div>
          <div class="bubble bubble-user">{{ turn.text }}</div>
        </div>
        {% endif %}

        {% if turn.role == "user" and turn.a2ui_response %}
        <div>
          <div class="bubble-label">User A2UI Response (Turn {{ turn.index }})</div>
          <div class="bubble bubble-a2ui">{{ turn.a2ui_response | tojson(indent=2) }}</div>
        </div>
        {% endif %}

        {% if turn.coach_thinking %}
        <div>
          <div class="bubble-label">Coach Thinking (Turn {{ turn.index }})</div>
          <div class="bubble" style="background: #f0f0f0; font-size: 0.8rem; color: #666; border-left: 3px solid #ccc;">
            <strong>{{ turn.coach_thinking.get('strategy', '') }}</strong>
            {% if turn.coach_thinking.get('observations') %}
            <br>{{ turn.coach_thinking.observations | join(' · ') }}
            {% endif %}
          </div>
        </div>
        {% endif %}

        {% if turn.role == "coach" and turn.text %}
        <div>
          <div class="bubble-label">Coach (Turn {{ turn.index }})</div>
          <div class="bubble bubble-coach">{{ turn.text }}</div>
        </div>
        {% endif %}

        {% if turn.suggested_replies %}
        <div style="display: flex; gap: 4px; flex-wrap: wrap; margin: 2px 0;">
          {% for reply in turn.suggested_replies %}
          <span style="background: #e3f2fd; color: #1565c0; padding: 2px 8px; border-radius: 12px; font-size: 0.75rem;">{{ reply }}</span>
          {% endfor %}
        </div>
        {% endif %}

        {% if turn.a2ui_payload %}
        <div>
          <div class="bubble-label">Coach A2UI (Turn {{ turn.index }})</div>
          <div class="bubble bubble-a2ui">
            {% for comp in turn.a2ui_payload.get('components', []) %}
            <div>
              {% if comp.kind == 'text' %}{{ comp.content | default('') | truncate(200) }}
              {% elif comp.kind == 'image' %}[Image: {{ comp.alt | default('') }}]
              {% elif comp.kind == 'slider' %}{{ comp.label | default('') }} ({{ comp.min | default(1) }}-{{ comp.max | default(10) }})
              {% elif comp.kind == 'select' %}{{ comp.label | default('') }}: {{ comp.options | map(attribute='label') | join(', ') if comp.options else '' }}
              {% elif comp.kind == 'text_input' %}{{ comp.label | default('') }}
              {% elif comp.kind == 'number_input' %}{{ comp.label | default('') }}
              {% elif comp.kind == 'multi_select' %}{{ comp.label | default('') }} (multi)
              {% else %}{{ comp.kind }}: {{ comp | tojson }}
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {% if turn.images %}
        {% for img in turn.images %}
        {% if img.src and img.src != '[data_url]' %}
        <div>
          <div class="bubble-label">Generated Image ({{ img.alt }})</div>
          <img class="eval-image" src="{{ img.src }}" alt="{{ img.alt }}" style="max-width: 384px; border-radius: 8px;" />
        </div>
        {% endif %}
        {% endfor %}
        {% endif %}
      {% endfor %}
    </div>

  </div>
</details>
{% endfor %}

{# ---- 附录 ---- #}
<h2>附录 A：Auditor System Prompt 模板</h2>
<details>
  <summary>展开查看 Auditor 提示词模板</summary>
  <div class="detail-content">
    <pre style="white-space: pre-wrap; font-size: 0.8rem; background: #f5f5f5; padding: 1rem; border-radius: 4px;">{{ auditor_prompt_template }}</pre>
  </div>
</details>

<h2>附录 B：Judge 评分标准（Rubric）</h2>
<details>
  <summary>展开查看 15 维度二元判定标准</summary>
  <div class="detail-content">
    <pre style="white-space: pre-wrap; font-size: 0.8rem; background: #f5f5f5; padding: 1rem; border-radius: 4px;">{{ judge_rubric }}</pre>
  </div>
</details>

<h2>附录 C：各 Seed 的 Auditor 实际提示词</h2>
{% for sr in seed_results %}
<details>
  <summary>{{ sr.seed.id }} — {{ sr.seed.name }}：Auditor Prompt</summary>
  <div class="detail-content">
    <h3>Persona</h3>
    <p><strong>{{ sr.seed.persona.name }}</strong> ({{ sr.seed.persona.language }})<br>{{ sr.seed.persona.background }}<br><em>{{ sr.seed.persona.personality }}</em></p>
    <h3>Goal</h3>
    <p>{{ sr.seed.goal }}</p>
    <h3>Expected Behaviors</h3>
    <table class="summary-table">
      <tr><th>Must</th><td>{{ sr.seed.expected_behaviors.must | join('<br>') }}</td></tr>
      <tr><th>Should</th><td>{{ sr.seed.expected_behaviors.should | join('<br>') }}</td></tr>
      <tr><th>Must NOT</th><td>{{ sr.seed.expected_behaviors.must_not | join('<br>') }}</td></tr>
    </table>
    <h3>Scoring Focus</h3>
    <p>Must-Pass: {{ sr.seed.scoring_focus.primary | join(', ') }}<br>Stretch: {{ sr.seed.scoring_focus.secondary | join(', ') }}</p>
  </div>
</details>
{% endfor %}

<h2>附录 D：Judge 完整评分输出</h2>
{% for sr in seed_results %}
<details>
  <summary>{{ sr.seed.id }} — {{ sr.seed.name }}：Judge 评分详情</summary>
  <div class="detail-content">
    {% for dim_id, dim in sr.score_card.scores.items() %}
    <div style="margin: 0.5rem 0; padding: 0.5rem; background: #f9f9f9; border-radius: 4px;">
      <strong>{{ dim_id | replace('_', ' ') }}</strong>:
      {% if dim.passed %}
      <span class="badge badge-pass">PASS</span>
      {% else %}
      <span class="badge {% if dim.failure_severity == 'critical' %}badge-fail{% else %}badge-fail-notable{% endif %}">FAIL ({{ dim.failure_severity or 'notable' }})</span>
      {% endif %}
      {% if dim.evidence_turns %}
      <span style="font-size: 0.75rem; color: var(--muted);">Turns: {{ dim.evidence_turns | join(', ') }}</span>
      {% endif %}
      <p style="font-size: 0.85rem; color: var(--muted); margin-top: 0.25rem;">{{ dim.justification }}</p>
    </div>
    {% endfor %}
    {% if sr.score_card.overall_assessment %}
    <div style="margin-top: 0.75rem;">
      <strong>Overall Assessment:</strong>
      <p>{{ sr.score_card.overall_assessment }}</p>
    </div>
    {% endif %}
    {% if sr.score_card.critical_failures %}
    <div style="margin-top: 0.5rem;">
      <strong>Critical Failures:</strong>
      <ul>{% for f in sr.score_card.critical_failures %}<li>{{ f }}</li>{% endfor %}</ul>
    </div>
    {% endif %}
  </div>
</details>
{% endfor %}

<div class="footer">
  Generated by voliti-eval {{ run_id }}<br>
  Config: server={{ config.server_url }}, assistant={{ config.assistant_id }}<br>
  Auditor: {{ config.auditor_model }} | Judge: {{ config.judge_model }}
</div>

</body>
</html>
