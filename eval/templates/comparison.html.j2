<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Voliti Eval Comparison</title>
<style>
  :root {
    --bg: #f7f4ee;
    --panel: #fffdf8;
    --ink: #1e1c19;
    --muted: #6f665c;
    --line: #ddd4c8;
    --pass: #2b6b4a;
    --warn: #b26a1f;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    padding: 24px;
    background: var(--bg);
    color: var(--ink);
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", sans-serif;
    line-height: 1.6;
  }
  .page { max-width: 1280px; margin: 0 auto; }
  h1, h2, h3 { margin: 0 0 12px; }
  h1 { font-size: 28px; }
  h2 { font-size: 20px; margin-top: 28px; }
  .meta { color: var(--muted); font-size: 14px; margin-bottom: 20px; }
  table {
    width: 100%;
    border-collapse: collapse;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    overflow: hidden;
    margin-bottom: 20px;
  }
  th, td {
    padding: 10px 12px;
    border-bottom: 1px solid var(--line);
    text-align: left;
    vertical-align: top;
    font-size: 14px;
  }
  th { background: #f1eadf; font-size: 13px; color: var(--muted); }
  tr:last-child td { border-bottom: none; }
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    background: #ece7df;
    color: var(--muted);
  }
  details {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 16px;
    margin-bottom: 12px;
    overflow: hidden;
  }
  summary {
    cursor: pointer;
    padding: 14px 16px;
    font-weight: 700;
    list-style: none;
  }
  summary::-webkit-details-marker { display: none; }
  .detail-body { padding: 0 16px 16px; }
  .mono { font-family: "SFMono-Regular", "JetBrains Mono", ui-monospace, monospace; font-size: 12px; }
</style>
</head>
<body>
<div class="page">
  <h1>Voliti Eval Comparison</h1>
  <div class="meta">
    {% for row in model_summaries %}
    {{ row.label }}{% if not loop.last %} vs {% endif %}
    {% endfor %}
  </div>

  <h2>模型总览</h2>
  <table>
    <thead>
      <tr>
        <th>模型</th>
        <th>运行次数</th>
        <th>Blocked</th>
        <th>总体通过率</th>
        <th>硬契约通过率</th>
        <th>行为维度通过率</th>
        <th>Must-Pass 通过率</th>
      </tr>
    </thead>
    <tbody>
      {% for row in model_summaries %}
      <tr>
        <td>{{ row.label }}</td>
        <td>{{ row.run_count }}</td>
        <td>{{ row.blocked_count }}</td>
        <td>{{ row.overall_pass_rate | display_percent }}</td>
        <td>{{ row.contract_pass_rate | display_percent }}</td>
        <td>{{ row.behavior_pass_rate | display_percent }}</td>
        <td>{{ row.must_pass_rate | display_percent }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>Per-Seed 双轴对比</h2>
  <table>
    <thead>
      <tr>
        <th>Seed</th>
        {% for row in model_summaries %}
        <th>{{ row.label }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in seed_rows %}
      <tr>
        <td>{{ row.seed_id }}<br>{{ row.seed_name }}</td>
        {% for model in row.models %}
        <td>
          <div>overall={{ model.average_pass_rate | display_percent }}</div>
          <div>contract={{ model.contract_pass_rate | display_percent }}</div>
          <div>behavior={{ model.behavior_pass_rate | display_percent }}</div>
          <div>blocked={{ model.blocked_count }}</div>
        </td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>维度对比</h2>
  <table>
    <thead>
      <tr>
        <th>维度</th>
        <th>类别</th>
        <th>评分来源</th>
        {% for row in model_summaries %}
        <th>{{ row.label }}</th>
        {% endfor %}
      </tr>
    </thead>
    <tbody>
      {% for row in dimension_rows %}
      <tr>
        <td class="mono">{{ row.dimension_id }}</td>
        <td>{{ row.category }}</td>
        <td>{{ row.score_source }}</td>
        {% for model in row.models %}
        <td>
          {{ model.pass_rate | display_percent }}
          <div class="mono">{{ model.pass_count }}/{{ model.total_count }}</div>
        </td>
        {% endfor %}
      </tr>
      {% endfor %}
    </tbody>
  </table>

  <h2>运行明细</h2>
  {% for row in seed_rows %}
  <details>
    <summary>{{ row.seed_id }} — {{ row.seed_name }}</summary>
    <div class="detail-body">
      {% for model in row.models %}
      <h3>{{ model.label }}</h3>
      {% if model.runs %}
      <table>
        <thead>
          <tr>
            <th>Run</th>
            <th>Status</th>
            <th>Pass Rate</th>
            <th>Must-Pass</th>
            <th>End Reason</th>
            <th>Transcript</th>
            <th>Score</th>
          </tr>
        </thead>
        <tbody>
          {% for run in model.runs %}
          <tr>
            <td>{{ run.run_id }}</td>
            <td>{% if run.execution_status == "blocked" %}BLOCKED{% else %}COMPLETED{% endif %}</td>
            <td>{{ run.pass_rate | display_percent }}</td>
            <td>{% if run.execution_status == "blocked" %}BLOCKED{% elif run.must_pass_met %}YES{% else %}NO{% endif %}</td>
            <td>{{ run.end_reason }}</td>
            <td class="mono">{{ run.transcript_path }}</td>
            <td class="mono">{{ run.score_path }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <div class="badge">该模型没有此 seed 结果</div>
      {% endif %}
      {% endfor %}
    </div>
  </details>
  {% endfor %}
</div>
</body>
</html>
