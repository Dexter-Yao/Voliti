      "caption": {
        "font-family": "var(--font-serif)",
        "font-size": "16px",
        "color": "var(--color-obsidian)",
        "margin-top": "var(--spacing-md)"
      },
      "timestamp": {
        "font-family": "var(--font-mono)",
        "font-size": "12px",
        "color": "var(--color-obsidian-40)",
        "text-align": "right",
        "margin-top": "var(--spacing-sm)"
      },
      "delete_button": {
        "color": "var(--color-risk-red)",
        "display": "none (show on hover)"
      },
      "forbidden": ["border-radius > 0 on card container", "gradient overlay on image", "like/share buttons"]
    },

    "LogEntry": {
      "description": "日志（Log）事件流条目，逆时间序，仅显示有数据的日子",
      "date_header": {
        "font-family": "var(--font-serif)",
        "font-size": "16px",
        "color": "var(--color-obsidian)"
      },
      "event_type": {
        "font-family": "var(--font-sans)",
        "font-size": "14px",
        "color": "var(--color-obsidian)"
      },
      "data_summary": {
        "font-family": "var(--font-mono)",
