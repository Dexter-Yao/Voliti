      ]
    },

    "ProtocolPromptCard": {
      "description": "微干预卡片，在 Coach 检测到高压力或疲劳信号时触发",
      "layout": "half fanout panel",
      "style": "minimalist, no decorative elements",
      "divider": {
        "element": "short horizontal line (──)",
        "color": "var(--color-obsidian-20)",
        "margin": "var(--spacing-md) 0"
      },
      "body_text": {
        "font-family": "var(--font-serif)",
        "font-size": "16px",
        "line-height": "1.6"
      },
      "question_text": {
        "font-family": "var(--font-serif)",
        "font-style": "normal",
        "quotes": "true (wrap in quotation marks)"
      },
      "actions": {
        "layout": "two buttons side by side",
        "primary": "ObsidianPill outline variant (「继续对话」)",
        "secondary": "ObsidianPill solid (「暂停一下」)"
      },
      "forbidden": ["warning icon", "red color", "emotional language", "exclamation marks"]
    },

    "TimestampSeparator": {
      "description": "聊天时间戳分隔组件，按消息间隔规则显示",
      "css_rules": {
        "font-family": "var(--font-mono)",
        "font-size": "11px",
        "color": "var(--color-obsidian-40)",
        "text-align": "center"
      },
      "display_rules": {
        "gap_lt_5min": {
          "condition": "消息间隔 < 5 分钟",
          "action": "不显示，消息合入同一组"
        },
        "gap_5_to_30min": {
          "condition": "消息间隔 5 ~ 30 分钟",
          "format": "仅时间，24h 制",
          "example": "09:12"
        },
        "gap_30min_to_midnight": {
          "condition": "消息间隔 30 分钟 ~ 当天跨午",
          "format": "居中，含上午/下午标记",
          "example_zh": "下午 3:20",
          "example_en": "3:20 PM"
        },
        "gap_cross_day_lt_7d": {
          "condition": "跨天且 < 7 天",
          "format": "相对日 + 时间",
          "example_zh": "昨天 15:20",
          "example_en": "Yesterday 15:20"
        },
        "gap_gte_7d": {
          "condition": "间隔 ≥ 7 天",
          "format": "完整日期 + 时间",
          "example_zh": "3月28日 09:00",
          "example_en": "Mar 28 09:00"
        }
      },
      "forbidden": ["inline timestamp within message row", "bold or colored timestamp text", "background behind timestamp"]
    },

